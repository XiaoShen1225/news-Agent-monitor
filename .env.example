# LLM API Keys
# Zhipu AI — 注册地址 https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key-here
# DeepSeek — 注册地址 https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# SMTP password for email notifications (optional)
SMTP_PASSWORD=your-smtp-password-here

# Dashboard access token (optional — 不设置则跳过鉴权)
DASHBOARD_TOKEN=

# HTTP proxy for mainland China users (optional)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
